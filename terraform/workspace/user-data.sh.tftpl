#!/bin/bash
# Workspace bootstrap. Rendered by Terraform's templatefile() — only the
# named template variables (server_js_b64, package_json_b64, cloud_init_b64,
# traefik_yml_b64, bucket_id, region, access_key_id, secret_access_key,
# user_id, platform_domain, platform_api_url, workspace_provision_secret) are
# substituted at apply time. All other shell
# variables are written as $NAME (no curlies) to avoid Terraform trying
# to interpolate them.
#
# Target: Ubuntu 24.04 LTS (the cloud-init.sh that runs at the end is
# apt-based and expects the 'ubuntu' user).
set -euxo pipefail
exec > >(tee /var/log/workspace-bootstrap.log) 2>&1

# ── 0. Base packages for both the workspace server and cloud-init.sh ─
export DEBIAN_FRONTEND=noninteractive
apt-get update -y
apt-get install -y -qq curl ca-certificates gnupg git

# ── 1. Node 20 (used by the workspace server, satisfies cloud-init.sh) ─
if ! command -v node >/dev/null \
  || [ "$(node -v | sed -E 's/^v([0-9]+)\..*/\1/')" -lt 20 ]; then
  curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
  apt-get install -y nodejs
fi

# ── 2. Drop the workspace HTTP server (backup/restore on :9099) ──────
mkdir -p /opt/workspace
echo "${server_js_b64gz}" | base64 -d | gunzip > /opt/workspace/server.js
echo "${package_json_b64}" | base64 -d         > /opt/workspace/package.json
( cd /opt/workspace && npm install --omit=dev --no-fund --no-audit )

# ── 3. Env file: discover instance id, public IP, hostname via IMDSv2 ─
TOKEN=$(curl -fsS -X PUT "http://169.254.169.254/latest/api/token" \
  -H "X-aws-ec2-metadata-token-ttl-seconds: 3600")
imds() {
  curl -fsS -H "X-aws-ec2-metadata-token: $TOKEN" \
    "http://169.254.169.254/latest/meta-data/$1"
}
INSTANCE_ID=$(imds instance-id)
PUBLIC_IP=$(imds public-ipv4)
INSTANCE_IP=$(imds public-ipv4)
PUBLIC_HOSTNAME=$(imds public-hostname)

# JWT secret shared by every process that talks to ONLYOFFICE Docs Server:
# the docs/sheets containers themselves (JWT validation), the backend's
# editor-config + callback endpoints, and the docs-agent/sheets-agent
# sidecars that construct editor URLs for their headless browser sessions.
# Generated once per instance — user-data is run-once by cloud-init, so
# this value is stable across reboots (it survives in /etc/workspace.env).
OFFICE_JWT_SECRET=$(openssl rand -hex 32)

# Shared env consumed by workspace.service AND the AI-IDE backend/frontend
# (their systemd units have EnvironmentFile=/etc/workspace.env), and also
# sourced by cloud-init.sh so it doesn't need to re-query IMDS.
# Intentionally does NOT include PORT — Environment= directives in each
# service unit override EnvironmentFile=, so putting PORT here would still
# be overridden, but we keep it absent to make each unit's port explicit.
# server.js falls back to 9099 when PORT is unset; the AI-IDE units set their own.
cat > /etc/workspace.env <<ENVEOF
INSTANCE_ID=$INSTANCE_ID
PUBLIC_IP=$PUBLIC_IP
PUBLIC_HOSTNAME=$PUBLIC_HOSTNAME
INSTANCE_IP=$INSTANCE_IP
INSTANCE_URL=http://$PUBLIC_HOSTNAME
BUCKET_ID=${bucket_id}
AWS_REGION=${region}
AWS_ACCESS_KEY_ID=${access_key_id}
AWS_SECRET_ACCESS_KEY=${secret_access_key}
USER_ID=${user_id}
PLATFORM_DOMAIN=${platform_domain}
PLATFORM_PROTOCOL=${platform_protocol}
PUBLIC_HOST=${user_id}.${platform_domain}
PROXY_ROUTER_URL=${proxy_router_url}
PLATFORM_API_URL=${platform_api_url}
WORKSPACE_PROVISION_SECRET=${workspace_provision_secret}
OFFICE_JWT_SECRET=$OFFICE_JWT_SECRET
# Public service URLs the Next.js frontend exposes to the browser. Written
# here (not as Environment= in the systemd unit) so the ai-ide-frontend
# unit can be baked into the workspace AMI without USER_ID hardcoded —
# the unit just EnvironmentFile=s this file and picks the per-instance
# values up automatically.
NEXT_PUBLIC_BACKEND_URL=${platform_protocol}://api-${user_id}.${platform_domain}
NEXT_PUBLIC_CODE_SERVER_URL=${platform_protocol}://ide-${user_id}.${platform_domain}
NEXT_PUBLIC_USER_ID=${user_id}
NEXT_PUBLIC_PLATFORM_DOMAIN=${platform_domain}
ENVEOF
chmod 600 /etc/workspace.env

# Also expose everything as system-wide env vars. /etc/profile.d/*.sh is
# sourced by every interactive login shell (e.g. `ssh ubuntu@...`), so
# these become available without any per-service EnvironmentFile= wiring.
# NOTE: this file is world-readable (required for non-root login shells to
# source it), which means the AWS credentials below are visible to every
# local user on the box. Acceptable here because the instance is single-
# tenant; revisit if you ever add untrusted users.
cat > /etc/profile.d/workspace.sh <<ENVEOF
# Workspace identity + AWS creds. Written by user-data.sh.tftpl on boot.
export INSTANCE_ID=$INSTANCE_ID
export PUBLIC_IP=$PUBLIC_IP
export PUBLIC_HOSTNAME=$PUBLIC_HOSTNAME
export INSTANCE_IP=$INSTANCE_IP
export INSTANCE_URL=http://$PUBLIC_HOSTNAME
export BUCKET_ID=${bucket_id}
export AWS_REGION=${region}
export AWS_ACCESS_KEY_ID=${access_key_id}
export AWS_SECRET_ACCESS_KEY=${secret_access_key}
export USER_ID=${user_id}
export PLATFORM_DOMAIN=${platform_domain}
export PLATFORM_PROTOCOL=${platform_protocol}
export PUBLIC_HOST=${user_id}.${platform_domain}
export PROXY_ROUTER_URL=${proxy_router_url}
export PLATFORM_API_URL=${platform_api_url}
# WORKSPACE_PROVISION_SECRET is intentionally NOT exported here — it lives only
# in /etc/workspace.env (mode 600), which provision.sh sources as root. Keeping
# it out of this world-readable profile.d file limits its exposure.
export OFFICE_JWT_SECRET=$OFFICE_JWT_SECRET
export NEXT_PUBLIC_BACKEND_URL=${platform_protocol}://api-${user_id}.${platform_domain}
export NEXT_PUBLIC_CODE_SERVER_URL=${platform_protocol}://ide-${user_id}.${platform_domain}
export NEXT_PUBLIC_USER_ID=${user_id}
export NEXT_PUBLIC_PLATFORM_DOMAIN=${platform_domain}
ENVEOF
chmod 644 /etc/profile.d/workspace.sh

# ── 4. Systemd unit for the workspace HTTP server ────────────────────
cat > /etc/systemd/system/workspace.service <<'UNITEOF'
[Unit]
Description=Workspace HTTP server (backup/restore)
After=network-online.target
Wants=network-online.target

[Service]
EnvironmentFile=/etc/workspace.env
WorkingDirectory=/opt/workspace
ExecStart=/usr/bin/node /opt/workspace/server.js
Restart=always
RestartSec=2
User=root

[Install]
WantedBy=multi-user.target
UNITEOF

systemctl daemon-reload
# `enable --now` is a no-op when the unit is already active — and on a
# baked workspace AMI it IS already active (the source's enabled state
# came along with the snapshot). Without an explicit restart, the
# process keeps running off the source's baked /etc/workspace.env.
# Always restart so the unit re-reads the file we just wrote above.
systemctl enable workspace.service
systemctl restart workspace.service

# ── 5. Docker + Traefik (per-user edge — owns :80) ───────────────────
# Traefik fronts every service on this box. Routes are discovered via the
# HTTP provider polling the landing-page backend so adding a service is a
# DB change, not a redeploy. The frontend used to bind :80 directly — now
# it lives on :3000 and Traefik proxies frontend.$USER_ID.$PLATFORM_DOMAIN
# to it.
#
# On a freshly-baked workspace AMI Docker is already installed (bake.sh
# step 8) and so are the apt sources/keyring it needs. Re-running the
# install path is wasteful and, worse, `gpg --dearmor -o <existing>`
# prompts on /dev/tty (which cloud-init doesn't have) and aborts the
# whole user-data run — see the 2026-06-07 bake-test post-mortem.
# Skip it when docker is already there; otherwise do the same setup we
# used to do pre-AMI on stock Ubuntu.
if command -v docker >/dev/null 2>&1 && systemctl list-unit-files docker.service >/dev/null 2>&1; then
  echo "docker already present (baked AMI) — skipping repo + apt install"
  systemctl enable --now docker || true
else
  install -m 0755 -d /etc/apt/keyrings
  # --yes so gpg overwrites the keyring without asking on /dev/tty.
  curl -fsSL https://download.docker.com/linux/ubuntu/gpg | \
    gpg --yes --batch --dearmor -o /etc/apt/keyrings/docker.gpg
  chmod a+r /etc/apt/keyrings/docker.gpg

  . /etc/os-release
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
https://download.docker.com/linux/ubuntu $VERSION_CODENAME stable" \
    > /etc/apt/sources.list.d/docker.list

  apt-get update -y
  apt-get install -y -qq \
    docker-ce docker-ce-cli containerd.io docker-buildx-plugin

  systemctl enable --now docker
fi

mkdir -p /etc/traefik
echo "${traefik_yml_b64}" | base64 -d > /etc/traefik/traefik.yml
chmod 644 /etc/traefik/traefik.yml

cat > /etc/systemd/system/traefik.service <<'UNITEOF'
[Unit]
Description=Traefik per-user edge proxy
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Restart=always
RestartSec=3
# --network host so Traefik can reach the host-bound app ports
# (frontend :3000, backend :8090, code-server :8080) at 127.0.0.1
# without per-service Docker networking. Routes resolved via HTTP provider.
ExecStartPre=-/usr/bin/docker rm -f traefik
ExecStart=/usr/bin/docker run --rm --name traefik \
  --network host \
  -v /etc/traefik/traefik.yml:/etc/traefik/traefik.yml:ro \
  traefik:v3.2
ExecStop=/usr/bin/docker stop traefik

[Install]
WantedBy=multi-user.target
UNITEOF

systemctl daemon-reload
# Same story as workspace.service above: on a baked AMI traefik is
# already running off the source's traefik.yml — it polls the source
# user's /api/traefik/user/<sourceId> and 404s every request to the
# new instance. Restart so it reads the freshly-templated yml.
systemctl enable traefik.service
systemctl restart traefik.service

# Belt-and-suspenders for the AMI-version marker: bake.sh writes
# /etc/ai-ide-ami-version when building the AMI, but the very first
# AMI we baked predated that step. provision.sh refuses to run without
# it; create a fallback marker here so a legacy AMI still provisions
# cleanly. Bakes that already include the file (most going forward)
# get a no-op.
if [ ! -f /etc/ai-ide-ami-version ]; then
  printf 'legacy-ami-no-marker-%s\n' "$(date -u +%Y%m%dT%H%M%SZ)" > /etc/ai-ide-ami-version
  chmod 644 /etc/ai-ide-ami-version
fi

# ── 6. Hand off to provision.sh (per-instance tail of the AMI bake) ──
# The workspace AMI already contains apt deps, Node, Claude CLI,
# code-server, backend/frontend node_modules, Docker, the Playwright +
# ONLYOFFICE images, and every systemd unit (units read identity from
# /etc/workspace.env, which we just wrote above). provision.sh is the
# short per-instance tail: git pull repos, reset ONLYOFFICE volumes for
# the new JWT secret, write the user-specific ~/.claude/CLAUDE.md, and
# kick the services so they re-read /etc/workspace.env.
mkdir -p /opt/cloud-init
for attempt in 1 2 3 4 5 6; do
  if curl -fsSL --max-time 30 -o /opt/cloud-init/provision.sh \
      "${proxy_router_url}/bootstrap/provision.sh"; then
    break
  fi
  echo "provision.sh fetch attempt $attempt failed, retrying in 5s..."
  sleep 5
done
test -s /opt/cloud-init/provision.sh
chmod +x /opt/cloud-init/provision.sh
/opt/cloud-init/provision.sh
