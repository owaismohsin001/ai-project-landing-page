# ─── App ──────────────────────────────────────────────────────────────
# The product name shown across the whole site. Change "AI" to anything.
NEXT_PUBLIC_APP_NAME=AI
# Public base URL of the app (used for Stripe redirect + email links).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────
# A MongoDB connection string (local or MongoDB Atlas).
MONGODB_URI=mongodb://localhost:27017/ai-landing

# ─── Auth ─────────────────────────────────────────────────────────────
# A long random string used to sign session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# ─── Stripe ───────────────────────────────────────────────────────────
# From https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# From `stripe listen` (CLI) or the Stripe webhook dashboard.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── AWS (workspace provisioning) ─────────────────────────────────────
# Needed to run `terraform apply` for per-user workspaces on signup.
# The IAM identity here must have permissions to create EC2 / S3 / IAM /
# security-group resources in the target region.
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Edge proxy + Traefik routing ─────────────────────────────────────
# Apex domain used to build per-user URLs: <service>.<userId>.<PLATFORM_DOMAIN>
PLATFORM_DOMAIN=platform.bytescripterz.com
# Scheme baked into per-user URLs (browser-facing). Flip to https once the
# proxy module has been applied with enable_https=true and ACM has issued
# the wildcard cert. Existing workspaces don't auto-update — re-provision
# or restart their frontend systemd unit to pick up the new env.
PLATFORM_PROTOCOL=http
# Base URL of the traefik-router service running on the proxy EC2. Comes
# from `terraform output router_base_url` in terraform/proxy/. Each user
# EC2's Traefik polls "${TRAEFIK_ROUTER_BASE_URL}/<userId>".
TRAEFIK_ROUTER_BASE_URL=http://<proxy-public-dns>:9100/api/traefik/user
